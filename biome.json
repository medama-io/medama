{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"files": {
		"includes": [
			"**",
			"!!**/.react-router",
			"!!**/build",
			"!!**/dist",
			"!!core/client",
			"!**/types.d.ts",
			"!dashboard/app/api/types.d.ts",
			"!bun.lock"
		]
	},
	"formatter": {
		"enabled": true,
		"useEditorconfig": true,
		"lineWidth": 80,
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"domains": {
			"react": "recommended",
			"test": "recommended",
			"project": "recommended"
		},
		"includes": [
			"**",
			"!**/types.d.ts",
			"!dashboard/app/api/types.d.ts",
			"!bun.lock"
		],
		"rules": {
			"recommended": true,
			"complexity": {
				"noImportantStyles": "error"
			},
			"correctness": {
				"noUndeclaredDependencies": "error",
				"noUnknownMediaFeatureName": "off",
				"noUnusedVariables": "error",
				"useExhaustiveDependencies": {
					"level": "error",
					"options": {
						"reportMissingDependenciesArray": true
					}
				}
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noUnknownAtRules": "off"
			},
			"style": {
				"noCommonJs": "error",
				"noDescendingSpecificity": "off",
				"noNonNullAssertion": "error",
				"useImportType": "error"
			}
		}
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"root": ".",
		"defaultBranch": "main"
	},
	"javascript": {
		"jsxRuntime": "transparent",
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"css": {
		"parser": {
			"cssModules": true
		}
	},
	"overrides": [
		{
			"includes": ["tracker/src/tracker.js"],
			"linter": {
				"enabled": false
			}
		},
		{
			"includes": ["tracker/tests/fixtures/**/*.html"],
			"linter": {
				"rules": {
					"a11y": {
						"useButtonType": "off"
					},
					"correctness": {
						"noUnusedVariables": "off"
					}
				}
			}
		},
		{
			"includes": ["tracker/tests/**/*.js"],
			"linter": {
				"rules": {
					"complexity": {
						"noUselessUndefinedInitialization": "off"
					},
					"style": {
						"useTemplate": "off"
					}
				}
			}
		},
		{
			"includes": ["tracker/playwright.config.js"],
			"linter": {
				"rules": {
					"style": {
						"noCommonJs": "off"
					}
				}
			}
		}
	]
}
